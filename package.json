{
  "name": "fabing-productions-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "emulators": "firebase emulators:start --only firestore,functions,hosting",
    "emulators:export": "firebase emulators:export .emulator-data",
    "deploy:hosting": "firebase deploy --only hosting:fabing",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "seed": "FIRESTORE_EMULATOR_HOST=localhost:8080 node scripts/seed-productions.js",
    "seed:prod": "node scripts/seed-productions.js --production"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "firebase": "^12.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.9.0",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
